{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/refs/tags/oxlint_v1.59.0/npm/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "dist/**",
    "out/**",
    "**/*.d.ts",
    "**/.trv/**",
    "**/fixtures/**",
    "**/resources/**",
    "**/ui/**",
    "**/api-client/**"
  ],
  "rules": {
    "eslint/no-unused-vars": "error",
    "eslint/sort-imports": [
      "error",
      {
        "ignoreCase": false,
        "ignoreDeclarationSort": false,
        "ignoreMemberSort": false,
        "memberSyntaxSortOrder": [
          "none",
          "all",
          "multiple",
          "single"
        ],
        "allowSeparatedGroups": true
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/DOC.ts",
        "**/DOC.tsx",
        "**/doc/**/*.ts",
        "**/doc/**/*.tsx"
      ],
      "rules": {
        "no-unused-vars": "off",
        "@typescript-eslint/no-unused-vars": "off"
      }
    },
    {
      "files": [
        "**/test/**/*.ts",
        "**/test/**/*.tsx",
        "**/support/test/**/*.ts",
        "**/support/test/**/*.tsx"
      ],
      "rules": {
        "no-unused-vars": "off",
        "@typescript-eslint/no-unused-vars": "off"
      }
    },
    {
      "files": [
        "module/compiler/**/*.ts",
        "module/transformer/**/*.ts",
        "**/support/transformer/**/*.ts",
        "**/support/transformer/**/*.tsx",
        "**/support/transformer.*.ts",
        "**/support/transformer.*.tsx"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}

{
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "files.exclude": {
    "**/.trv/**": true,
    ".git/**": true
  },
  "js/ts.tsserver.watchOptions": {
    "excludeDirectories": [
      ".git/**",
      "**/node_modules/**",
      "**/.trv/**",
      "related/vscode-plugin/out/**",
      "**/.angular/**",
    ],
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/*.code-search": true,
    "**/.dart_tool": true,
    "archived/**": true,
  }
}